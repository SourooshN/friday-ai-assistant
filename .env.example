# Friday AI Assistant Environment Configuration
# Copy this file to .env and fill in your values

# System Configuration
FRIDAY_ENV=development
FRIDAY_DEBUG=true
FRIDAY_LOG_LEVEL=INFO

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=openhermes:latest
OLLAMA_TIMEOUT=300

# Voice Configuration
VOICE_ENABLED=true
VOICE_ENGINE=vosk  # Options: vosk, google, azure
VOICE_WAKE_WORD=hey friday
TTS_ENGINE=pyttsx3  # Options: pyttsx3, coqui, elevenlabs
TTS_VOICE_ID=default

# Memory & Storage
VECTOR_DB_PATH=./data/memory/vectors
LONG_TERM_MEMORY_PATH=./data/memory/long_term
CACHE_DIR=./data/temp

# Security
SANDBOX_ENABLED=true
REQUIRE_CONFIRMATION=true
ALLOWED_DIRECTORIES=./data,./sandbox
BLOCKED_COMMANDS=rm -rf,format,del /f

# API Keys (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
ELEVENLABS_API_KEY=

# Web Automation
BROWSER_HEADLESS=true
BROWSER_TYPE=chrome  # Options: chrome, firefox, edge
SELENIUM_DRIVER_PATH=

# Development Tools
GIT_USER_NAME=Friday AI
GIT_USER_EMAIL=friday@localhost
DOCKER_HOST=unix:///var/run/docker.sock

# Social Media (Optional)
TWITTER_API_KEY=
TWITTER_API_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Smart Home (Optional)
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Monitoring
SENTRY_DSN=
TELEMETRY_ENABLED=false

# Performance
MAX_WORKERS=4
AGENT_TIMEOUT=300
MEMORY_LIMIT_MB=4096